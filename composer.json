{
	"name": "idmarinas/seo-bundle",
	"description": "Tools for SEO optimization in Symfony applications and sitemap generation and management.",
	"type": "symfony-bundle",
	"license": "BSD-3-Clause",
	"keywords": [
		"seo-bundle",
		"seo",
		"symfony-bundle"
	],
	"homepage": "https://github.com/idmarinas/seo-bundle",
	"authors": [
		{
			"name": "Iván Diaz Marinas (IDMarinas)",
			"email": "35842929+idmarinas@users.noreply.github.com",
			"role": "Author, Developer, Maintainer"
		}
	],
	"support": {
		"issues": "https://github.com/idmarinas/seo-bundle/issues"
	},
	"minimum-stability": "stable",
	"prefer-stable": true,
	"require": {
		"php": "^8.3",
		"ext-dom": "*",
		"idmarinas/common-bundle": "^3.5",
		"symfony/config": "^6.4 | ^7.1 | ^8.0",
		"symfony/dependency-injection": "^6.4 | ^7.1 | ^8.0",
		"symfony/expression-language": "^6.4 | ^7.1 | ^8.0",
		"symfony/framework-bundle": "^6.4 | ^7.1 | ^8.0",
		"symfony/property-access": "^6.4 | ^7.1 | ^8.0",
		"symfony/serializer": "^6.4 | ^7.1 | ^8.0",
		"symfony/string": "^6.4 | ^7.1 | ^8.0"
	},
	"require-dev": {
		"dama/doctrine-test-bundle": "^8.2",
		"doctrine/doctrine-fixtures-bundle": "^3.0 | ^4.0",
		"easycorp/easyadmin-bundle": "^4.27",
		"idmarinas/composer-plugin": "^1.0",
		"php-mock/php-mock-phpunit": "^2.12",
		"phpunit/phpunit": "^12.5",
		"rector/rector": "^1.2",
		"symfony/browser-kit": "^6.4 | ^7.1 | ^8.0",
		"symfony/console": "^6.4 | ^7.1 | ^8.0",
		"symfony/css-selector": "^6.4 | ^7.1 | ^8.0",
		"symfony/debug-bundle": "^6.4 | ^7.1 | ^8.0",
		"symfony/maker-bundle": "^1.61",
		"symfony/runtime": "^6.4 | ^7.1 | ^8.0",
		"symfony/stopwatch": "^6.4 | ^7.1 | ^8.0",
		"symfony/twig-bundle": "^6.4 | ^7.1 | ^8.0",
		"symfony/web-profiler-bundle": "^6.4 | ^7.1 | ^8.0",
		"zenstruck/foundry": "^2.6"
	},
	"autoload": {
		"psr-4": {
			"Idm\\Bundle\\Seo\\": "src/"
		},
		"files": [
			"src/functions.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"App\\": "tests/app/src/",
			"Idm\\Bundle\\Seo\\Tests\\": "tests/",
			"DataFixtures\\": "tests/Fixture/",
			"Factory\\": "tests/Factory/"
		}
	},
	"scripts": {
		"test:fixtures:load": [
			"php bin/console doctrine:schema:drop --env=test --force --ansi",
			"php bin/console doctrine:schema:update --env=test --force --ansi",
			"php bin/console doctrine:fixtures:load --env=test -n --ansi"
		],
		"dev:fixtures:load": [
			"php bin/console doctrine:schema:drop --env=dev --force --ansi",
			"php bin/console doctrine:schema:update --env=dev --force --ansi",
			"php bin/console doctrine:fixtures:load --env=dev -n --ansi"
		]
	},
	"config": {
		"allow-plugins": {
			"composer/package-versions-deprecated": true,
			"idmarinas/composer-plugin": false,
			"symfony/flex": true,
			"symfony/runtime": true
		},
		"optimize-autoloader": false,
		"preferred-install": {
			"*": "dist"
		},
		"sort-packages": true
	},
	"funding": [
		{
			"type": "paypal",
			"url": "https://www.paypal.me/idmarinas"
		},
		{
			"type": "github-sponsors",
			"url": "https://github.com/sponsors/idmarinas"
		}
	],
	"extra": {
		"thanks": {
			"name": "idmarinas/seo-bundle",
			"url": "https://github.com/idmarinas/seo-bundle"
		}
	}
}
